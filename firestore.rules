rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasLiked(fromUid, targetUid) {
      return exists(/databases/$(database)/documents/users/$(fromUid)/actions/$(targetUid))
        && get(/databases/$(database)/documents/users/$(fromUid)/actions/$(targetUid)).data.action == 'like';
    }

    function hasMutualLike(uidA, uidB) {
      return signedIn() && hasLiked(uidA, uidB) && hasLiked(uidB, uidA);
    }

    function hasContactShare(ownerUid, viewerUid) {
      return exists(/databases/$(database)/documents/contactShares/$(ownerUid)/allowedViewers/$(viewerUid));
    }

    function publicProfileHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'displayName',
        'displayNameKey',
        'regionId',
        'region',
        'regionKey',
        'comuna',
        'comunaKey',
        'countryCode',
        'locationPrecision',
        'missingIds',
        'duplicateIds',
        'lastActiveAt',
        'profileVisible'
      ]);
    }

    function publicProfileHasNoPrivateFields() {
      return !request.resource.data.keys().hasAny([
        'description',
        'email',
        'contactType',
        'contactValue',
        'contactVisible',
        'publicContactType',
        'publicContactValue',
        'phone',
        'telefono',
        'whatsapp',
        'instagram'
      ]);
    }

    function privateProfileHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'description',
        'updatedAt'
      ]);
    }

    function privateProfileHasValidDescription() {
      return request.resource.data.description is string
        && request.resource.data.description.size() <= 200;
    }

    function privateProfileExistingHasNoContactFields() {
      return !resource.data.keys().hasAny([
        'contactType',
        'contactValue',
        'contactVisible',
        'email',
        'phone',
        'telefono',
        'whatsapp',
        'instagram'
      ]);
    }

    function privateContactHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'contactType',
        'contactValue',
        'updatedAt'
      ]);
    }

    function privateContactHasValidContact() {
      return (
        request.resource.data.contactType == 'email'
        || request.resource.data.contactType == 'phone'
      )
      && request.resource.data.contactValue is string
      && request.resource.data.contactValue.size() > 0;
    }

    function usernameHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'displayName',
        'displayNameKey',
        'createdAt',
        'updatedAt'
      ]);
    }

    function usernameIsValid(usernameKey) {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.displayNameKey == usernameKey
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 15;
    }

    function actionHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'fromUid',
        'targetUid',
        'action',
        'createdAt',
        'updatedAt'
      ]);
    }

    function actionIsValid(fromUid, targetUid) {
      return request.resource.data.fromUid == fromUid
        && request.resource.data.targetUid == targetUid
        && (
          request.resource.data.action == 'like'
          || request.resource.data.action == 'dislike'
        );
    }

    function dailyUsageHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'dayKey',
        'likesUsed',
        'dislikesUsed',
        'userSearchesUsed',
        'communeChangesUsed',
        'updatedAt'
      ]);
    }

    function blockedUserHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'blockedUid',
        'createdAt'
      ]);
    }

    function blockedUserIsValid(blockedUid) {
      return request.resource.data.blockedUid == blockedUid
        && blockedUid != request.auth.uid;
    }

    function contactShareHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'ownerUid',
        'viewerUid',
        'createdAt'
      ]);
    }

    function contactShareIsValid(ownerUid, viewerUid) {
      return request.resource.data.ownerUid == ownerUid
        && request.resource.data.viewerUid == viewerUid;
    }

    function reportHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'reporterUid',
        'reportedUid',
        'reason',
        'details',
        'source',
        'status',
        'createdAt',
        'updatedAt'
      ]);
    }

    function reportReasonIsValid() {
      return request.resource.data.reason == 'inappropriate_contact'
        || request.resource.data.reason == 'scam'
        || request.resource.data.reason == 'spam'
        || request.resource.data.reason == 'fake_profile'
        || request.resource.data.reason == 'other';
    }

    function reportIsValid() {
      return request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        && reportReasonIsValid()
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 500
        && request.resource.data.source is string
        && request.resource.data.source.size() > 0
        && request.resource.data.source.size() <= 50
        && request.resource.data.status == 'open';
    }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);

      match /cards/{cardId} {
        allow read, write: if isOwner(uid);
      }

      match /actions/{targetUid} {
        allow read: if signedIn()
          && (request.auth.uid == uid || request.auth.uid == targetUid);

        allow create, update: if isOwner(uid)
          && actionHasOnlyAllowedFields()
          && actionIsValid(uid, targetUid);

        allow delete: if isOwner(uid);
      }

      match /dailyUsage/{dayKey} {
        allow read: if isOwner(uid);

        allow create, update: if isOwner(uid)
          && dailyUsageHasOnlyAllowedFields();

        allow delete: if isOwner(uid);
      }

      match /blockedUsers/{blockedUid} {
        allow read: if isOwner(uid)
          || (
            signedIn()
            && request.auth.uid == blockedUid
          );

        allow create, update: if isOwner(uid)
          && blockedUserHasOnlyAllowedFields()
          && blockedUserIsValid(blockedUid);

        allow delete: if isOwner(uid);
      }
    }

    match /usernames/{usernameKey} {
      allow read: if signedIn();

      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/usernames/$(usernameKey))
        && usernameHasOnlyAllowedFields()
        && usernameIsValid(usernameKey);

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && usernameHasOnlyAllowedFields()
        && usernameIsValid(usernameKey);

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /publicProfiles/{uid} {
  allow read: if signedIn();

  allow create, update: if isOwner(uid)
    && publicProfileHasOnlyAllowedFields()
    && publicProfileHasNoPrivateFields();

  allow delete: if isOwner(uid);
}

    match /privateProfiles/{uid} {
      allow read: if (isOwner(uid) || hasMutualLike(request.auth.uid, uid))
        && privateProfileExistingHasNoContactFields();

      allow create, update: if isOwner(uid)
        && privateProfileHasOnlyAllowedFields()
        && privateProfileHasValidDescription();

      allow delete: if isOwner(uid);
    }

    match /privateContacts/{uid} {
      allow read: if isOwner(uid)
        || (
          signedIn()
          && hasMutualLike(request.auth.uid, uid)
          && hasContactShare(uid, request.auth.uid)
        );

      allow create, update: if isOwner(uid)
        && privateContactHasOnlyAllowedFields()
        && privateContactHasValidContact();

      allow delete: if isOwner(uid);
    }

    match /contactShares/{ownerUid} {
  allow read: if isOwner(ownerUid);

  allow create, update: if false;

  allow delete: if isOwner(ownerUid);

  match /allowedViewers/{viewerUid} {
    allow read: if signedIn()
      && (
        request.auth.uid == ownerUid
        || request.auth.uid == viewerUid
      );

    allow create, update: if isOwner(ownerUid)
      && contactShareHasOnlyAllowedFields()
      && contactShareIsValid(ownerUid, viewerUid);

    allow delete: if signedIn()
      && (
        request.auth.uid == ownerUid
        || request.auth.uid == viewerUid
      );
  }
}

    match /reports/{reportId} {
      allow create: if signedIn()
        && reportHasOnlyAllowedFields()
        && reportIsValid();

      allow read, update, delete: if false;
    }

    match /userEntitlements/{uid} {
  allow read: if isOwner(uid);

  allow create, update: if false;

  allow delete: if isOwner(uid);
}
  }
}