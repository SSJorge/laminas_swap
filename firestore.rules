rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function publicProfileHasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly([
        'displayName',
        'regionId',
        'region',
        'regionKey',
        'comuna',
        'comunaKey',
        'countryCode',
        'locationPrecision',
        'description',
        'contactVisible',
        'publicContactType',
        'publicContactValue',
        'missingIds',
        'duplicateIds',
        'lastActiveAt',
        'profileVisible'
      ]);
    }

    function publicProfileHasNoPrivateContact() {
      return !request.resource.data.keys().hasAny([
        'email',
        'contactType',
        'contactValue',
        'phone',
        'telefono',
        'whatsapp',
        'instagram'
      ]);
    }

    function publicProfileHasValidDescription() {
      return !request.resource.data.keys().hasAny(['description'])
        || (
          request.resource.data.description is string
          && request.resource.data.description.size() <= 200
        );
    }

    function publicProfileHasValidPublicContact() {
      return !request.resource.data.keys().hasAny([
        'publicContactType',
        'publicContactValue'
      ])
      || (
        request.resource.data.keys().hasAll([
          'publicContactType',
          'publicContactValue'
        ])
        && (
          request.resource.data.publicContactType == 'email'
          || request.resource.data.publicContactType == 'phone'
        )
        && request.resource.data.publicContactValue is string
        && request.resource.data.publicContactValue.size() > 0
      );
    }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);

      match /cards/{cardId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /publicProfiles/{uid} {
      allow read: if signedIn();

      allow create, update: if isOwner(uid)
        && publicProfileHasOnlyAllowedFields()
        && publicProfileHasNoPrivateContact()
        && publicProfileHasValidDescription()
        && publicProfileHasValidPublicContact();

      allow delete: if false;
    }
  }
}
